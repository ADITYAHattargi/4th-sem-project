PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=career_app
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Optional Cloudflare Images upload storage.
# If these are empty, uploads fall back to local data URLs for development.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGES_API_TOKEN=
CLOUDFLARE_IMAGES_VARIANT=public

# Optional Cloudflare R2 upload storage through Wrangler CLI.
# When set, R2 is used before Cloudflare Images.
CLOUDFLARE_R2_BUCKET=aditya
CLOUDFLARE_R2_PUBLIC_URL=https://pub-b22d2ee562fe41bbaae0004139862815.r2.dev

# Optional fallback auth style. Prefer CLOUDFLARE_IMAGES_API_TOKEN instead.
CLOUDFLARE_API_EMAIL=
CLOUDFLARE_GLOBAL_API_KEY=
